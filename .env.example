APP_TITLE=STAL Analogs Storage
APP_VERSION=0.1.0
DEBUG=false

# Docker/публикация порта. Для прямого доступа без nginx поставьте APP_HOST=0.0.0.0
APP_HOST=127.0.0.1
APP_PORT=8000

# Bearer token для внутреннего Telegram-бота (Authorization: Bearer <token>)
API_TOKEN=change-me-to-a-long-random-secret

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# Для Docker/CI удобнее хранить service account целиком в одной строке JSON:
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SHEET_NAME=Лист1

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Сессии агента (контекст диалога)
SESSIONS_DB_PATH=data/sessions.db
AGENT_HISTORY_LIMIT=10
AGENT_SESSION_TTL_MINUTES=30

# S3-совместимое хранилище файлов (MinIO в docker-compose)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agent-files
S3_REGION=us-east-1
S3_USE_SSL=false

# Логин/пароль для MinIO (docker-compose). Должны совпадать с S3_ACCESS_KEY/S3_SECRET_KEY
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
